<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a12">
  <title>Bug Hunters — EZ-AZ</title>
  <link rel="icon" type="image/png" href="/icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100%;
      background: #0a0a12;
      color: #e0e0e0;
      font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    a { color: inherit; text-decoration: none; }

    /* Store banner */
    .store-banner {
      position: sticky;
      top: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 24px;
      background: rgba(10,10,18,0.96);
      border-bottom: 1px solid rgba(0,255,200,0.12);
      backdrop-filter: blur(8px);
    }

    .store-banner-link {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.7rem;
      color: #00ffc8;
      letter-spacing: 0.06em;
    }

    .store-banner-link:hover { color: #fff; }

    /* Page */
    .page {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px 80px;
    }

    .page-heading {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(1rem, 3vw, 1.6rem);
      color: #00ffc8;
      text-align: center;
      margin-bottom: 8px;
      letter-spacing: 0.06em;
    }

    .page-sub {
      text-align: center;
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 40px;
    }

    /* Flash messages */
    .flash {
      padding: 12px 18px;
      border-radius: 10px;
      margin-bottom: 24px;
      font-size: 0.9rem;
      font-weight: 600;
    }

    .flash.notice { background: rgba(0,255,200,0.12); border: 1px solid rgba(0,255,200,0.3); color: #00ffc8; }
    .flash.alert  { background: rgba(255,80,80,0.12);  border: 1px solid rgba(255,80,80,0.3);  color: #ff8080; }

    /* Section headers */
    .section-title {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.65rem;
      color: #555;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    /* Submit form */
    .submit-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 28px;
      margin-bottom: 48px;
    }

    .login-nudge {
      background: rgba(0,255,200,0.06);
      border: 1px solid rgba(0,255,200,0.2);
      border-radius: 10px;
      padding: 20px;
      color: #888;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .login-nudge strong { color: #00ffc8; }

    .form-row {
      margin-bottom: 18px;
    }

    .form-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 700;
      color: #aaa;
      margin-bottom: 8px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .form-textarea {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #e0e0e0;
      font-family: inherit;
      font-size: 0.95rem;
      padding: 12px 14px;
      transition: border-color 0.15s;
      resize: vertical;
      min-height: 90px;
    }
    .form-textarea:focus { outline: none; border-color: #00ffc8; }

    /* Custom dropdown */
    .custom-select-wrap { position: relative; }
    .custom-select-trigger {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #e0e0e0;
      font-family: inherit;
      font-size: 0.95rem;
      padding: 12px 40px 12px 14px;
      text-align: left;
      cursor: pointer;
      transition: border-color 0.15s;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .custom-select-trigger:after {
      content: '▾';
      font-size: 0.8rem;
      color: #555;
      flex-shrink: 0;
    }
    .custom-select-trigger.open,
    .custom-select-trigger:focus { outline: none; border-color: #00ffc8; }
    .custom-select-options {
      display: none;
      position: absolute;
      top: calc(100% + 4px);
      left: 0; right: 0;
      background: #141420;
      border: 1px solid rgba(0,255,200,0.25);
      border-radius: 8px;
      z-index: 100;
      max-height: 280px;
      overflow-y: auto;
      scrollbar-width: none;
    }
    .custom-select-options::-webkit-scrollbar { display: none; }
    .custom-select-options.open { display: block; }
    .custom-select-option {
      padding: 11px 14px;
      font-size: 0.9rem;
      color: #ccc;
      cursor: pointer;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      transition: background 0.1s, color 0.1s;
    }
    .custom-select-option:last-child { border-bottom: none; }
    .custom-select-option:hover { background: rgba(0,255,200,0.08); color: #fff; }
    .custom-select-option.selected { color: #00ffc8; background: rgba(0,255,200,0.06); }

    .submit-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: rgba(0,255,200,0.1);
      border: 2px solid #00ffc8;
      border-radius: 999px;
      color: #00ffc8;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.06em;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }

    .submit-btn:hover {
      background: #00ffc8;
      color: #0a0a12;
    }

    /* Bug board */
    .bug-empty {
      text-align: center;
      color: #555;
      font-size: 0.9rem;
      padding: 40px 0;
    }

    .bug-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 18px 20px;
      margin-bottom: 14px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
      transition: border-color 0.15s;
    }

    .bug-card:hover { border-color: rgba(255,255,255,0.16); }

    .bug-card.squashed {
      opacity: 0.6;
      border-color: rgba(0,255,200,0.15);
    }

    .bug-vote-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
      min-width: 44px;
    }

    .vote-btn {
      background: none;
      border: 2px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #666;
      font-size: 1.1rem;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }

    .vote-btn:hover {
      border-color: #00ffc8;
      color: #00ffc8;
    }

    .vote-btn.voted {
      border-color: #00ffc8;
      color: #00ffc8;
      background: rgba(0,255,200,0.08);
    }

    .vote-count {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #777;
    }

    .bug-body { flex: 1; min-width: 0; }

    .bug-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .bug-game-tag {
      display: inline-block;
      padding: 3px 10px;
      background: rgba(0,255,200,0.08);
      border: 1px solid rgba(0,255,200,0.2);
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 700;
      color: #00ffc8;
      letter-spacing: 0.03em;
    }

    .bug-squashed-badge {
      display: inline-block;
      padding: 3px 10px;
      background: rgba(0,255,80,0.1);
      border: 1px solid rgba(0,255,80,0.3);
      border-radius: 999px;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      color: #00ff80;
      letter-spacing: 0.06em;
    }

    .bug-submitter {
      font-size: 0.75rem;
      color: #555;
    }

    .bug-description {
      font-size: 0.95rem;
      color: #ccc;
      line-height: 1.55;
    }

    .bug-pending-badge {
      display: inline-block;
      padding: 3px 10px;
      background: rgba(255,200,0,0.08);
      border: 1px solid rgba(255,200,0,0.25);
      border-radius: 999px;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      color: #ffc800;
      letter-spacing: 0.06em;
    }

    .bug-dismissed-badge {
      display: inline-block;
      padding: 3px 10px;
      background: rgba(255,80,80,0.08);
      border: 1px solid rgba(255,80,80,0.2);
      border-radius: 999px;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      color: #ff8080;
      letter-spacing: 0.06em;
    }

    .my-bugs-section { margin-bottom: 48px; }

    .leaderboard {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 48px;
    }
    .leaderboard-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 13px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .leaderboard-row:last-child { border-bottom: none; }
    .leaderboard-rank {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #444;
      width: 24px;
      text-align: center;
      flex-shrink: 0;
    }
    .leaderboard-row:nth-child(1) .leaderboard-rank { color: #ffd700; }
    .leaderboard-row:nth-child(2) .leaderboard-rank { color: #c0c0c0; }
    .leaderboard-row:nth-child(3) .leaderboard-rank { color: #cd7f32; }
    .leaderboard-name { flex: 1; font-weight: 700; color: #ddd; font-size: 0.9rem; }
    .leaderboard-pts {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.5rem;
      color: #00ffc8;
    }
    .leaderboard-total { font-size: 0.75rem; color: #555; }
    .leaderboard-empty { padding: 24px; text-align: center; color: #444; font-size: 0.85rem; }

    .az-note {
      margin-top: 10px;
      padding: 10px 14px;
      background: rgba(0,255,200,0.05);
      border-left: 3px solid #00ffc8;
      border-radius: 0 8px 8px 0;
      font-size: 0.85rem;
      color: #aaa;
      line-height: 1.5;
    }
    .az-note-label {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.4rem;
      color: #00ffc8;
      letter-spacing: 0.08em;
      display: block;
      margin-bottom: 5px;
    }

    .bug-actions {
      display: flex;
      gap: 8px;
      margin-top: 10px;
    }
    .btn-edit, .btn-delete {
      padding: 5px 12px;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      border: 1px solid;
      transition: background 0.15s, color 0.15s;
    }
    .btn-edit {
      background: rgba(255,255,255,0.04);
      border-color: rgba(255,255,255,0.15);
      color: #aaa;
    }
    .btn-edit:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .btn-delete {
      background: rgba(255,80,80,0.06);
      border-color: rgba(255,80,80,0.2);
      color: #ff8080;
    }
    .btn-delete:hover { background: rgba(255,80,80,0.15); }
    .inline-edit-form {
      display: none;
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .inline-edit-form.open { display: block; }
  </style>
</head>
<body>

<header class="store-banner">
  <a href="/" class="store-banner-link">← EZ-AZ</a>
  <span style="font-family: 'Press Start 2P', monospace; font-size: 0.55rem; color: #555; letter-spacing: 0.08em;">BUG HUNTERS</span>
</header>

<main class="page">
  <% if flash[:notice] %>
    <div class="flash notice"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="flash alert"><%= flash[:alert] %></div>
  <% end %>

  <h1 class="page-heading">Squash a Bug</h1>
  <p class="page-sub">Found something broken? Tell Az. Every bug you find makes the store better.</p>

  <!-- Submit section -->
  <div class="submit-panel">
    <p class="section-title">Report a Bug</p>

    <% if @player %>
      <%= form_tag bugs_path, method: :post do %>
        <div class="form-row">
          <label class="form-label" for="game_slug">Which game? (or General)</label>
          <input type="hidden" id="game_slug" name="game_slug" value="">
          <div class="custom-select-wrap">
            <button type="button" class="custom-select-trigger" id="gameSelectTrigger" onclick="toggleSelect()">
              <span id="gameSelectLabel">General / Store</span>
            </button>
            <div class="custom-select-options" id="gameSelectOptions">
              <div class="custom-select-option selected" data-value="" onclick="pickOption(this, '', 'General / Store')">General / Store</div>
              <% @games.each do |game| %>
                <div class="custom-select-option" data-value="<%= game[:slug] %>" onclick="pickOption(this, '<%= game[:slug] %>', '<%= game[:title] %>')"><%= game[:title] %></div>
              <% end %>
            </div>
          </div>
        </div>
        <div class="form-row">
          <label class="form-label" for="description">What happened?</label>
          <textarea class="form-textarea" id="description" name="description" placeholder="Describe what you expected vs what actually happened..."></textarea>
        </div>
        <button type="submit" class="submit-btn">Report Bug 🐛</button>
      <% end %>
    <% else %>
      <div class="login-nudge">
        <strong>You need a gamer tag to squash bugs.</strong><br>
        Play any game and claim your tag first, then come back and report away.
      </div>
    <% end %>
  </div>

  <!-- My pending bugs -->
  <% if @my_pending.any? %>
    <div class="my-bugs-section">
      <p class="section-title">Your Reported Bugs</p>
      <% @my_pending.each do |bug| %>
        <div class="bug-card">
          <div class="bug-vote-col">
            <span style="font-size:1.4rem;">🐛</span>
          </div>
          <div class="bug-body">
            <div class="bug-meta">
              <% if bug.game_slug.present? %>
                <span class="bug-game-tag"><%= bug.game_slug.tr('-', ' ').titleize %></span>
              <% else %>
                <span class="bug-game-tag">Store</span>
              <% end %>
                      <% if bug.status == 'dismissed' %>
                <span class="bug-dismissed-badge">✕ Dismissed</span>
              <% else %>
                <span class="bug-pending-badge">⏳ Pending Review</span>
              <% end %>
            </div>
            <p class="bug-description"><%= bug.description %></p>
            <% if bug.status == 'pending' %>
              <div class="bug-actions">
                <button class="btn-edit" type="button" onclick="toggleEdit(<%= bug.id %>)">Edit</button>
              </div>
              <div class="inline-edit-form" id="edit-form-<%= bug.id %>">
                <%= form_tag bug_path(bug), method: :patch do %>
                  <div class="form-row">
                    <label class="form-label">Game</label>
                    <div class="custom-select-wrap">
                      <input type="hidden" name="game_slug" id="edit-game-slug-<%= bug.id %>" value="<%= bug.game_slug %>">
                      <button type="button" class="custom-select-trigger" onclick="toggleEditSelect(<%= bug.id %>)">
                        <span id="edit-game-label-<%= bug.id %>"><%= bug.game_slug.present? ? bug.game_slug.tr('-',' ').titleize : 'General / Store' %></span>
                      </button>
                      <div class="custom-select-options" id="edit-game-options-<%= bug.id %>">
                        <div class="custom-select-option<%= bug.game_slug.blank? ? ' selected' : '' %>" onclick="pickEditOption(<%= bug.id %>, '', 'General / Store')">General / Store</div>
                        <% @games.each do |game| %>
                          <div class="custom-select-option<%= bug.game_slug == game[:slug] ? ' selected' : '' %>" onclick="pickEditOption(<%= bug.id %>, '<%= game[:slug] %>', '<%= game[:title] %>')"><%= game[:title] %></div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="form-row">
                    <label class="form-label">What happened?</label>
                    <textarea class="form-textarea" name="description"><%= bug.description %></textarea>
                  </div>
                  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                    <div style="display:flex;gap:8px;">
                      <button type="submit" class="submit-btn" style="font-size:0.5rem;padding:8px 16px;">Save</button>
                      <button type="button" class="btn-edit" onclick="toggleEdit(<%= bug.id %>)">Cancel</button>
                    </div>
                    <%= form_tag bug_path(bug), method: :delete, style: "margin:0" do %>
                      <button class="btn-delete" type="submit" onclick="return confirm('Remove this bug report?')">Delete</button>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Leaderboard -->
  <p class="section-title">Top Bug Hunters 🏆</p>
  <div class="leaderboard" style="margin-bottom:48px;">
    <% if @leaderboard.any? %>
      <% @leaderboard.each_with_index do |entry, i| %>
        <div class="leaderboard-row">
          <span class="leaderboard-rank">#<%= i + 1 %></span>
          <span class="leaderboard-name"><%= entry.username %></span>
          <span class="leaderboard-total"><%= entry.total %> bug<%= entry.total == 1 ? '' : 's' %></span>
          <span class="leaderboard-pts"><%= entry.points %> pts</span>
        </div>
      <% end %>
    <% else %>
      <div class="leaderboard-empty">No hunters yet. Be the first to find a bug!</div>
    <% end %>
  </div>

  <!-- Bug board -->
  <p class="section-title">Bug Board</p>

  <% if @bugs.empty? %>
    <p class="bug-empty">No bugs on the board yet. Be the first to find one!</p>
  <% else %>
    <% @bugs.each do |bug| %>
      <div class="bug-card<%= bug.status == 'squashed' ? ' squashed' : '' %>">
        <div class="bug-vote-col">
          <button
            class="vote-btn<%= @player&.bug_votes&.exists?(bug_report_id: bug.id) ? ' voted' : '' %>"
            data-bug-id="<%= bug.id %>"
            onclick="handleVote(this, <%= bug.id %>)"
            title="<%= @player ? 'Toggle vote' : 'Login to vote' %>"
          >👍</button>
          <span class="vote-count" id="vote-count-<%= bug.id %>"><%= bug.votes_count %></span>
        </div>
        <div class="bug-body">
          <div class="bug-meta">
            <span class="bug-game-tag"><%= bug.game_slug.present? ? (Game.find(bug.game_slug)&.dig(:title) || bug.game_slug) : "Store" %></span>
            <% if bug.status == 'squashed' %>
              <span class="bug-squashed-badge">SQUASHED ✓</span>
            <% end %>
            <span class="bug-submitter">by <%= bug.player.username %></span>
          </div>
          <p class="bug-description"><%= bug.description %></p>
          <% if bug.az_note.present? %>
            <div class="az-note">
              <span class="az-note-label">🦕 Az says</span>
              <%= bug.az_note %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</main>

<script>
  var playerLoggedIn = <%= @player ? 'true' : 'false' %>;
  var votedBugs = new Set(<%= raw (@player ? @player.bug_votes.pluck(:bug_report_id).to_json : '[]') %>);

  function handleVote(btn, bugId) {
    if (!playerLoggedIn) {
      alert('Play a game first to claim your gamer tag, then you can vote!');
      return;
    }

    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    var headers = { 'Content-Type': 'application/json', 'Accept': 'application/json' };
    if (csrfToken) headers['X-CSRF-Token'] = csrfToken.content;

    fetch('/bugs/' + bugId + '/vote', {
      method: 'POST',
      headers: headers,
      credentials: 'same-origin'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var countEl = document.getElementById('vote-count-' + bugId);
      if (countEl) countEl.textContent = data.votes;
      btn.classList.toggle('voted');
    })
    .catch(function(err) { console.error('Vote failed', err); });
  }

  function toggleEdit(id) {
    document.getElementById('edit-form-' + id).classList.toggle('open');
  }

  function toggleEditSelect(id) {
    document.getElementById('edit-game-options-' + id).classList.toggle('open');
  }

  function pickEditOption(id, value, label) {
    document.getElementById('edit-game-slug-' + id).value = value;
    document.getElementById('edit-game-label-' + id).textContent = label;
    var opts = document.getElementById('edit-game-options-' + id);
    opts.querySelectorAll('.custom-select-option').forEach(function(o) { o.classList.remove('selected'); });
    event.target.classList.add('selected');
    opts.classList.remove('open');
  }

  function toggleSelect() {
    document.getElementById('gameSelectTrigger').classList.toggle('open');
    document.getElementById('gameSelectOptions').classList.toggle('open');
  }

  function pickOption(el, value, label) {
    document.getElementById('game_slug').value = value;
    document.getElementById('gameSelectLabel').textContent = label;
    document.querySelectorAll('.custom-select-option').forEach(function(o) { o.classList.remove('selected'); });
    el.classList.add('selected');
    document.getElementById('gameSelectTrigger').classList.remove('open');
    document.getElementById('gameSelectOptions').classList.remove('open');
  }

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.custom-select-wrap')) {
      document.getElementById('gameSelectTrigger').classList.remove('open');
      document.getElementById('gameSelectOptions').classList.remove('open');
    }
  });
</script>

</body>
</html>
