<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a12">
  <title>Watch — EZ-AZ</title>
  <link rel="icon" type="image/png" href="/icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      background: #0a0a12;
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* --- Player --- */
    .player-wrap {
      position: fixed;
      inset: 0;
      z-index: 0;
      background: #000;
    }

    #yt-player {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    #player-blocker {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1;
      cursor: default;
    }

    /* --- Header overlay --- */
    .watch-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 10;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 24px 60px;
      background: linear-gradient(to bottom, rgba(10,10,18,0.92) 0%, transparent 100%);
      pointer-events: none;
    }

    .watch-header a, .watch-header button { pointer-events: auto; }

    .channel-bar {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .store-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 10px;
      background: rgba(0,255,200,0.1);
      border: 2px solid rgba(0,255,200,0.35);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.6rem, 1vw, 0.85rem);
      font-weight: 900;
      color: #00ffc8;
      text-decoration: none;
      line-height: 1;
      transition: background 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .store-link:hover, .store-link:focus {
      background: rgba(0,255,200,0.2);
      border-color: #00ffc8;
      outline: none;
    }

    .guide-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 10px;
      background: rgba(255,255,255,0.06);
      border: 2px solid rgba(255,255,255,0.2);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.6rem, 1vw, 0.85rem);
      font-weight: 900;
      color: #ccc;
      text-decoration: none;
      line-height: 1;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
      white-space: nowrap;
    }

    .guide-btn:hover, .guide-btn:focus {
      background: rgba(255,255,255,0.12);
      border-color: rgba(255,255,255,0.4);
      color: #fff;
      outline: none;
    }

    .remote-focus {
      outline: 3px solid #00ffc8 !important;
      outline-offset: 4px;
      background: rgba(0,255,200,0.15) !important;
      border-color: #00ffc8 !important;
      color: #00ffc8 !important;
    }

    .ch-divider {
      width: 1px; height: 24px;
      background: rgba(255,255,255,0.2);
    }

    .ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.75rem, 1.5vw, 1.1rem);
      color: #00ffc8;
      line-height: 1;
    }

    .ch-emoji {
      font-size: clamp(1.2rem, 2.5vw, 1.8rem);
      line-height: 1;
    }

    .ch-name {
      font-size: clamp(0.75rem, 1.5vw, 1.1rem);
      font-weight: 800;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .watch-qr {
      width: clamp(70px, 7vw, 110px);
      height: clamp(70px, 7vw, 110px);
      flex-shrink: 0;
      background: #0a0a12;
      padding: 6px;
      border-radius: 8px;
      border: 1px solid rgba(0,255,200,0.25);
    }

    /* --- Footer overlay --- */
    .watch-footer {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 10;
      padding: 80px 24px 24px;
      background: linear-gradient(to top, rgba(10,10,18,0.95) 0%, rgba(10,10,18,0.5) 60%, transparent 100%);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .watch-footer.hud-visible { opacity: 1; }


    .video-meta { flex: 1; min-width: 0; }

    .video-title {
      font-size: clamp(0.9rem, 1.8vw, 1.3rem);
      font-weight: 700;
      color: #fff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .video-sub {
      margin-top: 4px;
      font-size: clamp(0.7rem, 1.2vw, 0.95rem);
      color: #888;
      display: flex;
      gap: 12px;
    }

    .video-pos { color: #00ffc8; font-weight: 700; }

    .nav-hint {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .nav-key {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 8px;
      border: 2px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      font-size: clamp(0.8rem, 1.3vw, 1.1rem);
      font-weight: 700;
      color: #ccc;
      white-space: nowrap;
    }

    .nav-key .k {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      border-radius: 6px;
      background: rgba(255,255,255,0.12);
      font-size: 1em;
      color: #fff;
      padding: 0 4px;
    }

    .nav-key.k-channel .k { color: #00ffc8; background: rgba(0,255,200,0.15); }
    .nav-key.k-video   .k { color: #ffe44d; background: rgba(255,228,77,0.15); }
    .nav-key.k-play    .k { color: #ff6ec7; background: rgba(255,110,199,0.15); }
    .nav-key.k-home    .k { color: #aaa;    background: rgba(255,255,255,0.1); }

    /* --- Channel guide bar --- */
    .guide {
      position: fixed;
      bottom: -160px;
      left: 0; right: 0;
      z-index: 20;
      display: flex;
      gap: 12px;
      padding: 16px 24px 20px;
      background: rgba(10, 10, 18, 0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      overflow-x: auto;
      scrollbar-width: none;
      transition: bottom 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .guide::-webkit-scrollbar { display: none; }

    .guide.visible { bottom: 0; }

    .guide-ch {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      padding: 12px 20px;
      border: 2px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      min-width: 130px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      pointer-events: auto;
    }

    .guide-ch:hover { border-color: rgba(255,255,255,0.3); }

    .guide-ch.active {
      border-color: #00ffc8;
      background: rgba(0,255,200,0.1);
    }

    .guide-ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #555;
    }

    .guide-ch.active .guide-ch-num { color: #00ffc8; }

    .guide-ch-emoji { font-size: 1.6rem; }

    .guide-ch-name {
      font-size: 0.72rem;
      font-weight: 700;
      color: #ccc;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.2;
    }

    .guide-ch.active .guide-ch-name { color: #fff; }

    /* --- TV Guide overlay (full-screen schedule grid) --- */
    .tv-guide {
      position: fixed;
      inset: 0;
      z-index: 30;
      background: rgba(5, 5, 12, 0.97);
      backdrop-filter: blur(6px);
      display: flex;
      flex-direction: column;
      padding: 32px 48px 32px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
      overflow-y: auto;
    }
    .tv-guide.visible {
      opacity: 1;
      pointer-events: auto;
    }
    .tv-guide-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      flex-shrink: 0;
    }
    .tv-guide-title {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(1rem, 2vw, 1.6rem);
      color: #00ffc8;
      letter-spacing: 0.06em;
    }
    .tv-guide-clock {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.8rem, 1.4vw, 1.1rem);
      color: #fff;
      letter-spacing: 0.06em;
    }
    .tv-guide-clock-label {
      color: #555;
      font-size: 0.7em;
      margin-right: 8px;
    }
    /* ── EPG day tabs ──────────────────────────────────────────────────── */
    .epg-day-tabs {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .epg-tab {
      padding: 7px 14px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.04);
      font-family: 'Press Start 2P', monospace;
      font-size: 0.5rem;
      color: #888;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
      white-space: nowrap;
      pointer-events: auto;
    }
    .epg-tab:hover { background: rgba(255,255,255,0.1); color: #ddd; }
    .epg-tab.is-today { color: #00ffc8; border-color: rgba(0,255,200,0.3); }
    .epg-tab.active { background: rgba(0,255,200,0.12); border-color: #00ffc8; color: #00ffc8; }

    /* ── EPG layout ────────────────────────────────────────────────────── */
    .epg-scroll {
      flex: 1;
      min-height: 0;
      overflow: auto;
      scrollbar-width: none;
    }
    .epg-scroll::-webkit-scrollbar { display: none; }
    .epg-inner {
      position: relative;
      display: inline-flex;
      flex-direction: column;
      min-width: 100%;
    }
    .epg-ruler-row {
      display: flex;
      position: sticky;
      top: 0;
      z-index: 20;
      height: 36px;
      flex-shrink: 0;
      background: rgba(5,5,12,0.98);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .epg-corner {
      width: 160px;
      flex-shrink: 0;
      position: sticky;
      left: 0;
      z-index: 25;
      background: rgba(5,5,12,0.98);
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .epg-ruler-ticks {
      position: relative;
      flex: 1;
    }
    .epg-tick {
      position: absolute;
      top: 0;
      transform: translateX(-50%);
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      color: #555;
      white-space: nowrap;
      padding: 10px 0 0;
      letter-spacing: 0.04em;
    }
    .epg-ch-row {
      display: flex;
      flex-shrink: 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .epg-ch-cell {
      width: 160px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      padding: 0 12px;
      position: sticky;
      left: 0;
      z-index: 5;
      background: rgba(5,5,12,0.98);
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .epg-ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.45rem;
      color: #444;
    }
    .epg-ch-inner { display: flex; align-items: center; gap: 8px; }
    .epg-ch-emoji { font-size: 1.8rem; line-height: 1; flex-shrink: 0; }
    .epg-ch-name { font-size: 0.95rem; font-weight: 800; color: #ddd; line-height: 1.3; }
    .epg-row-content {
      position: relative;
      flex: 1;
    }
    .epg-off {
      position: absolute;
      top: 0; bottom: 0;
      background: repeating-linear-gradient(
        -45deg,
        rgba(0,0,0,0.3),
        rgba(0,0,0,0.3) 6px,
        rgba(0,0,0,0.15) 6px,
        rgba(0,0,0,0.15) 12px
      );
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .epg-off-label {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #333;
      letter-spacing: 0.1em;
    }
    .epg-block {
      position: absolute;
      border-radius: 6px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      overflow: hidden;
      padding: 8px 10px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      transition: background 0.15s, border-color 0.15s;
      box-sizing: border-box;
    }
    .epg-block:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }
    .epg-block.is-now {
      background: rgba(0,255,200,0.1);
      border-color: rgba(0,255,200,0.5);
    }
    .epg-block.is-now:hover { background: rgba(0,255,200,0.18); }
    .epg-block.is-past { opacity: 0.35; }
    .epg-block-time {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.42rem;
      color: #666;
      line-height: 1;
    }
    .epg-block.is-now .epg-block-time { color: #00ffc8; }
    .epg-block-title {
      font-size: 0.78rem;
      font-weight: 700;
      color: #ccc;
      line-height: 1.35;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }
    .epg-block.is-now .epg-block-title { color: #fff; }
    .epg-block-dur { font-size: 0.62rem; color: #555; }
    .epg-now-badge {
      display: inline-block;
      padding: 1px 5px;
      border-radius: 3px;
      background: #00ffc8;
      color: #000;
      font-size: 0.45rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      margin-top: 2px;
      width: fit-content;
    }
    .epg-now-line {
      position: absolute;
      top: 0; bottom: 0;
      width: 2px;
      background: #00ffc8;
      box-shadow: 0 0 8px rgba(0,255,200,0.6);
      z-index: 10;
      pointer-events: none;
    }
    .epg-now-line::before {
      content: '';
      position: absolute;
      top: 4px;
      left: -4px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #00ffc8;
      box-shadow: 0 0 8px rgba(0,255,200,0.8);
    }
    .tv-guide-hint {
      flex-shrink: 0;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: clamp(0.7rem, 1vw, 0.9rem);
      color: #666;
    }
    .tv-guide-hint .k {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 22px;
      padding: 0 6px;
      margin-right: 6px;
      border-radius: 5px;
      background: rgba(255,255,255,0.08);
      color: #ddd;
      font-weight: 700;
    }
  </style>
</head>
<body>

<div class="player-wrap">
  <div id="yt-player"></div>
</div>
<div id="player-blocker"></div>

<header class="watch-header">
  <div class="channel-bar">
    <a href="/" class="store-link">← Store</a>
    <div class="ch-divider"></div>
    <button class="guide-btn" onclick="openTvGuide()" aria-label="Open TV Guide">📺 TV Guide</button>
    <div class="ch-divider"></div>
    <span class="ch-num"  id="chNum">CH 01</span>
    <span class="ch-emoji" id="chEmoji"></span>
    <span class="ch-name"  id="chName"></span>
  </div>
  <div class="watch-qr"><%= @qr_code_svg %></div>
</header>

<footer class="watch-footer">
  <div class="video-meta">
    <div class="video-title" id="videoTitle"></div>
    <div class="video-sub">
      <span class="video-pos"  id="videoPos"></span>
      <span class="video-note" id="videoNote"></span>
    </div>
    <div class="nav-hint">
      <span class="nav-key k-channel"><span class="k">▲▼</span> Change Channel</span>
      <span class="nav-key k-video"><span class="k">◀▶</span> Skip Video</span>
      <span class="nav-key k-play"><span class="k">●</span> Play / Pause</span>
      <span class="nav-key k-video"><span class="k">G</span> TV Guide</span>
      <span class="nav-key k-home"><span class="k">⌫</span> Go Home</span>
    </div>
  </div>
</footer>

<div class="guide" id="guide">
  <% @tracks.each_with_index do |track, i| %>
    <div class="guide-ch<%= i == 0 ? ' active' : '' %>"
         data-idx="<%= i %>"
         onclick="selectChannel(<%= i %>)">
      <span class="guide-ch-num">CH <%= sprintf('%02d', i + 1) %></span>
      <span class="guide-ch-emoji"><%= track[:emoji] %></span>
      <span class="guide-ch-name"><%= track[:title] %></span>
    </div>
  <% end %>
</div>

<!-- Full-screen TV Guide overlay -->
<section class="tv-guide" id="tvGuide" aria-hidden="true">
  <header class="tv-guide-header" style="flex-shrink:0;">
    <div class="tv-guide-title" style="white-space:nowrap;">📺 TV GUIDE</div>
    <div class="epg-day-tabs" id="epgDayTabs"></div>
    <div class="tv-guide-clock" style="white-space:nowrap;">
      <span class="tv-guide-clock-label">NOW</span>
      <span id="tvGuideClock">--:--</span>
    </div>
    <button class="guide-btn" onclick="closeTvGuide()" style="pointer-events:auto;white-space:nowrap;">✕ Close</button>
  </header>

  <div class="epg-scroll" id="epgScroll">
    <div class="epg-inner" id="epgInner"></div>
  </div>

  <div class="tv-guide-hint" style="flex-shrink:0;">
    <span><span class="k">G</span> Close</span>
    <span><span class="k">▲▼</span> Scroll channels</span>
    <span>Click a NOW block to tune in</span>
  </div>
</section>

<script>
  // Globals needed before YouTube IFrame API calls the callback
  window._ytCallbacks = [];
  window.onYouTubeIframeAPIReady = function() {
    window._ytReady = true;
    window._ytCallbacks.forEach(function(fn) { fn(); });
    window._ytCallbacks = [];
  };
</script>
<script src="https://www.youtube.com/iframe_api"></script>

<script type="module">
  import { createConsumer } from "<%= asset_path('actioncable.esm.js') %>";

  var tracks       = <%= raw @tracks.to_json %>;
  var HOLIDAYS     = <%= raw @holiday_ranges.to_json %>;
  var token        = <%= @room.tv_token.to_json.html_safe %>;
  var trackIdx     = 0;
  var videoIdx     = 0;       // index into the channel's daily-shuffled schedule
  var player       = null;
  var syncTimer    = null;
  var guideTimer   = null;
  var hudTimer     = null;
  var clockTimer   = null;
  var footer       = document.querySelector('.watch-footer');
  var remoteFocus  = 'channels'; // 'channels' | 'header'
  var headerIdx    = 1;          // 0 = Store, 1 = TV Guide

  var HEADER_BTNS = [
    document.querySelector('.store-link'),
    document.querySelector('.guide-btn')
  ];

  function setHeaderFocus(idx) {
    remoteFocus = 'header';
    headerIdx   = idx;
    HEADER_BTNS.forEach(function(el, i) {
      if (el) el.classList.toggle('remote-focus', i === idx);
    });
  }

  function clearHeaderFocus() {
    remoteFocus = 'channels';
    HEADER_BTNS.forEach(function(el) { if (el) el.classList.remove('remote-focus'); });
  }

  function activateHeader() {
    if (headerIdx === 0) { window.location.href = '/'; }
    else { openTvGuide(); clearHeaderFocus(); }
  }

  // ── Scheduler ────────────────────────────────────────────────────────────
  // Each channel has a deterministic per-day shuffle of its videos. The
  // schedule starts at local midnight and loops if total content < 24h. Two
  // viewers tuning in at the same time on the same day always see the same
  // thing. Tomorrow is a different shuffle.

  function dayKey() {
    var d = new Date();
    var start = new Date(d.getFullYear(), 0, 0);
    var diff  = d - start + (start.getTimezoneOffset() - d.getTimezoneOffset()) * 60 * 1000;
    return d.getFullYear() * 1000 + Math.floor(diff / 86400000);
  }

  function strHash(s) {
    var h = 0;
    for (var i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
    return h;
  }

  function lcg(seed) {
    var s = seed | 0;
    return function() {
      s = (Math.imul(s, 1664525) + 1013904223) | 0;
      return ((s >>> 0) / 4294967296);
    };
  }

  function dailyShuffle(videos, slug) {
    var seed = (dayKey() ^ strHash(slug)) | 0;
    var r    = lcg(seed);
    var arr  = videos.slice();
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(r() * (i + 1));
      var t = arr[i]; arr[i] = arr[j]; arr[j] = t;
    }
    return arr;
  }

  function durationOf(v) { return Math.max(60, v.duration_s || 600); }

  function totalDuration(sched) {
    return sched.reduce(function(s, v) { return s + durationOf(v); }, 0);
  }

  function secondsSinceMidnight() {
    var n = new Date();
    return n.getHours() * 3600 + n.getMinutes() * 60 + n.getSeconds();
  }

  // For a channel + current local time, return the schedule + which video is
  // playing now and how many seconds into it we are.
  function nowPlaying(track) {
    var sched = dailyShuffle(track.videos, track.slug);
    var total = totalDuration(sched);
    var t     = secondsSinceMidnight() % total;
    var acc   = 0;
    for (var i = 0; i < sched.length; i++) {
      var d = durationOf(sched[i]);
      if (t < acc + d) {
        return {
          schedule:    sched,
          videoIndex:  i,
          offsetS:     Math.floor(t - acc),
          remainingS:  Math.floor(d - (t - acc)),
          startsAtMin: minutesOfDay(acc, total)
        };
      }
      acc += d;
    }
    return { schedule: sched, videoIndex: 0, offsetS: 0, remainingS: durationOf(sched[0]), startsAtMin: 0 };
  }

  // Wall-clock string for "this many seconds from now"
  function clockStr(secsFromNow) {
    var d = new Date(Date.now() + secsFromNow * 1000);
    var h = d.getHours(), m = d.getMinutes();
    return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
  }

  function minutesOfDay(secs, total) {
    return Math.floor(((secsForToday() - secsForToday() % total) + secs) / 60);
  }
  function secsForToday() { return secondsSinceMidnight(); }

  function upcoming(track, count) {
    var info  = nowPlaying(track);
    var sched = info.schedule;
    var out   = [];
    var fromNow = info.remainingS;
    var i = (info.videoIndex + 1) % sched.length;
    while (out.length < count) {
      out.push({
        video: sched[i],
        startsAtClock: clockStr(fromNow),
        endsAtClock:   clockStr(fromNow + durationOf(sched[i]))
      });
      fromNow += durationOf(sched[i]);
      i = (i + 1) % sched.length;
    }
    return out;
  }

  // The shuffled schedule we're playing through right now for the active channel.
  // Recomputed on channel switch.
  var activeSchedule = [];

  function showHud() {
    footer.classList.add('hud-visible');
    clearTimeout(hudTimer);
    hudTimer = setTimeout(function() { footer.classList.remove('hud-visible'); }, 4000);
  }

  // ── Display ──────────────────────────────────────────────────────────────

  function updateDisplay() {
    var t = tracks[trackIdx];
    var v = activeSchedule[videoIdx] || t.videos[0];
    document.getElementById('chNum').textContent   = 'CH ' + String(trackIdx + 1).padStart(2, '0');
    document.getElementById('chEmoji').textContent = t.emoji;
    document.getElementById('chName').textContent  = t.title;
    document.getElementById('videoTitle').textContent = v.title;
    document.getElementById('videoPos').textContent   = (videoIdx + 1) + ' / ' + activeSchedule.length;
    document.getElementById('videoNote').textContent  = v.note || '';
    document.querySelectorAll('.guide-ch').forEach(function(el, i) {
      el.classList.toggle('active', i === trackIdx);
    });
    var activeGuide = document.querySelector('.guide-ch.active');
    if (activeGuide) activeGuide.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  function showGuide() {
    document.getElementById('guide').classList.add('visible');
    clearTimeout(guideTimer);
    guideTimer = setTimeout(function() {
      document.getElementById('guide').classList.remove('visible');
    }, 3000);
  }

  // ── Navigation ───────────────────────────────────────────────────────────

  function loadVideoAt(startSeconds) {
    if (!player) return;
    var v = activeSchedule[videoIdx];
    if (!v) return;
    player.loadVideoById({ videoId: v.youtube_id, startSeconds: Math.max(0, Math.floor(startSeconds || 0)) });
  }

  // Tune to a channel — picks the video that should be playing right now and
  // jumps to the correct offset, like switching channels on a real TV.
  window.selectChannel = function(idx) {
    trackIdx = idx;
    var info = nowPlaying(tracks[idx]);
    activeSchedule = info.schedule;
    videoIdx = info.videoIndex;
    loadVideoAt(info.offsetS);
    updateDisplay();
    showGuide();
    savePosition();
  };

  function changeChannel(delta) {
    selectChannel((trackIdx + delta + tracks.length) % tracks.length);
  }

  // Manual skip — moves through the daily-shuffled schedule, not the original
  // track order. New video starts from 0.
  function advanceVideo(delta) {
    if (!activeSchedule.length) return;
    videoIdx = (videoIdx + delta + activeSchedule.length) % activeSchedule.length;
    loadVideoAt(0);
    updateDisplay();
    savePosition();
  }

  function togglePlayPause() {
    if (!player) return;
    var state = player.getPlayerState();
    if (state === YT.PlayerState.PLAYING) {
      player.pauseVideo();
    } else {
      player.playVideo();
    }
  }

  function handleNav(dir) {
    if (isGuideOpen()) {
      if (dir === 'back' || dir === 'guide') closeTvGuide();
      return;
    }
    if (dir === 'guide') { openTvGuide(); return; }

    if (remoteFocus === 'header') {
      switch (dir) {
        case 'left':   setHeaderFocus(0);    break;
        case 'right':  setHeaderFocus(1);    break;
        case 'select': activateHeader();     break;
        case 'down':   clearHeaderFocus();   break;
        case 'back':   clearHeaderFocus();   break;
      }
      return;
    }

    showHud();
    switch (dir) {
      case 'up':
        if (trackIdx === 0) { setHeaderFocus(1); }
        else { changeChannel(-1); }
        break;
      case 'down':   changeChannel(1);     break;
      case 'left':   advanceVideo(-1);     break;
      case 'right':  advanceVideo(1);      break;
      case 'select':
        document.getElementById('guide').classList.contains('visible') ? openTvGuide() : togglePlayPause();
        break;
      case 'back':   window.location.href = '/'; break;
    }
  }

  document.addEventListener('keydown', function(e) {
    if (isGuideOpen()) {
      if (e.key === 'g' || e.key === 'G' || e.key === 'Escape') {
        e.preventDefault(); closeTvGuide();
      }
      return;
    }

    if (remoteFocus === 'header') {
      switch (e.key) {
        case 'ArrowLeft':  e.preventDefault(); setHeaderFocus(0);  break;
        case 'ArrowRight': e.preventDefault(); setHeaderFocus(1);  break;
        case 'ArrowDown':  e.preventDefault(); clearHeaderFocus(); break;
        case 'Enter': case ' ': e.preventDefault(); activateHeader(); break;
        case 'Escape':     clearHeaderFocus(); break;
      }
      return;
    }

    showHud();
    switch (e.key) {
      case 'ArrowUp':
        e.preventDefault();
        trackIdx === 0 ? setHeaderFocus(1) : changeChannel(-1);
        break;
      case 'ArrowDown':                    e.preventDefault(); changeChannel(1);  break;
      case 'ArrowLeft':                    e.preventDefault(); advanceVideo(-1);  break;
      case 'ArrowRight':                   e.preventDefault(); advanceVideo(1);   break;
      case 'Enter': case ' ':
        e.preventDefault();
        document.getElementById('guide').classList.contains('visible') ? openTvGuide() : togglePlayPause();
        break;
      case 'g': case 'G':                  e.preventDefault(); openTvGuide();     break;
      case 'Escape': case 'Backspace':     window.location.href = '/';            break;
    }
  });

  // ── TV Guide overlay ─────────────────────────────────────────────────────

  function isGuideOpen() {
    return document.getElementById('tvGuide').classList.contains('visible');
  }

  window.openTvGuide = function openTvGuide() {
    epgDate = new Date();
    buildDayTabs();
    renderEpg();
    document.getElementById('tvGuide').classList.add('visible');
    document.getElementById('tvGuide').setAttribute('aria-hidden', 'false');
    scrollEpgToNow();
    if (clockTimer) clearInterval(clockTimer);
    clockTimer = setInterval(function() {
      var el = document.getElementById('tvGuideClock');
      if (el) el.textContent = clockStr(0);
    }, 30000);
  };

  window.closeTvGuide = function closeTvGuide() {
    document.getElementById('tvGuide').classList.remove('visible');
    document.getElementById('tvGuide').setAttribute('aria-hidden', 'true');
    if (clockTimer) { clearInterval(clockTimer); clockTimer = null; }
  };

  function escapeHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ── Store hours helpers ───────────────────────────────────────────────────

  var WEEKDAY_OPEN = 16 * 60;
  var WEEKEND_OPEN = 7 * 60 + 30;
  var CLOSE_730PM  = 19 * 60 + 30;
  var CLOSE_500PM  = 17 * 60;

  function localIso(date) {
    return date.getFullYear() + '-' +
      String(date.getMonth() + 1).padStart(2, '0') + '-' +
      String(date.getDate()).padStart(2, '0');
  }

  function isHoliday(date) {
    var iso = localIso(date);
    return HOLIDAYS.some(function(h) { return iso >= h.from && iso <= h.to; });
  }

  function hoursForDay(date) {
    var dow = date.getDay();
    if (dow === 0) return { open: WEEKEND_OPEN, close: CLOSE_500PM };
    if (dow === 6) return { open: WEEKEND_OPEN, close: CLOSE_730PM };
    if (isHoliday(date)) return { open: WEEKEND_OPEN, close: CLOSE_730PM };
    return { open: WEEKDAY_OPEN, close: CLOSE_730PM };
  }

  function fmt12(minutes) {
    var h = Math.floor(minutes / 60);
    var m = minutes % 60;
    var ampm = h >= 12 ? 'pm' : 'am';
    var h12 = h > 12 ? h - 12 : (h === 0 ? 12 : h);
    return h12 + (m ? ':' + String(m).padStart(2, '0') : '') + ampm;
  }

  function weekDates() {
    var today = new Date();
    var dow = today.getDay();
    var monday = new Date(today);
    monday.setDate(today.getDate() - (dow === 0 ? 6 : dow - 1));
    monday.setHours(0, 0, 0, 0);
    var days = [];
    for (var i = 0; i < 7; i++) {
      var d = new Date(monday);
      d.setDate(monday.getDate() + i);
      days.push(d);
    }
    return days;
  }

  function isToday(date) {
    var t = new Date();
    return date.getDate() === t.getDate() &&
           date.getMonth() === t.getMonth() &&
           date.getFullYear() === t.getFullYear();
  }

  // ── EPG engine ────────────────────────────────────────────────────────────

  var PX_PER_MIN   = 8;
  var CH_HEIGHT    = 160;
  var EPG_BUFFER   = 30;
  var epgDate      = null;

  function dayKeyForDate(date) {
    var start = new Date(date.getFullYear(), 0, 0);
    var diff  = date - start + (start.getTimezoneOffset() - date.getTimezoneOffset()) * 60 * 1000;
    return date.getFullYear() * 1000 + Math.floor(diff / 86400000);
  }

  function dailyShuffleForDate(videos, slug, date) {
    var seed = (dayKeyForDate(date) ^ strHash(slug)) | 0;
    var r    = lcg(seed);
    var arr  = videos.slice();
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(r() * (i + 1));
      var t = arr[i]; arr[i] = arr[j]; arr[j] = t;
    }
    return arr;
  }

  function computeChannelSchedule(track, date) {
    var sched    = dailyShuffleForDate(track.videos, track.slug, date);
    var h        = hoursForDay(date);
    var openMin  = h.open;
    var closeMin = h.close;
    var slots    = [];
    var tMin     = 0;
    var idx      = 0;
    var limit    = closeMin + EPG_BUFFER + 60;

    while (tMin < limit && idx < sched.length * 30) {
      var v      = sched[idx % sched.length];
      var durMin = Math.max(1, Math.round(durationOf(v) / 60));
      var endMin = tMin + durMin;

      if (endMin > openMin && tMin < closeMin) {
        slots.push({ video: v, startMin: tMin, endMin: Math.min(endMin, closeMin) });
      }

      tMin = endMin;
      idx++;
    }
    return { slots: slots, openMin: openMin, closeMin: closeMin };
  }

  function buildDayTabs() {
    var tabsEl = document.getElementById('epgDayTabs');
    if (!tabsEl) return;
    tabsEl.innerHTML = '';
    var days     = weekDates();
    var DAY_ABBR = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    days.forEach(function(date, i) {
      var btn    = document.createElement('button');
      var today  = isToday(date);
      var active = epgDate && localIso(date) === localIso(epgDate);
      btn.className = 'epg-tab' + (today ? ' is-today' : '') + (active ? ' active' : '');
      btn.textContent = DAY_ABBR[i] + ' ' + date.getDate();
      btn.addEventListener('click', (function(d) {
        return function() { epgDate = d; buildDayTabs(); renderEpg(); if (isToday(d)) scrollEpgToNow(); };
      }(date)));
      tabsEl.appendChild(btn);
    });
  }

  function scrollEpgToNow() {
    setTimeout(function() {
      if (!epgDate) return;
      var h      = hoursForDay(epgDate);
      var nowMin = new Date().getHours() * 60 + new Date().getMinutes();
      var offset = (nowMin - (h.open - EPG_BUFFER)) * PX_PER_MIN;
      var wrap   = document.getElementById('epgScroll');
      if (wrap) wrap.scrollLeft = Math.max(0, 160 + offset - wrap.clientWidth / 3);
    }, 60);
  }

  function renderEpg() {
    var date = epgDate || new Date();
    var h    = hoursForDay(date);
    var displayStart = h.open  - EPG_BUFFER;
    var displayEnd   = h.close + EPG_BUFFER;
    var totalPx = (displayEnd - displayStart) * PX_PER_MIN;

    // Clock
    var clockEl = document.getElementById('tvGuideClock');
    if (clockEl) clockEl.textContent = clockStr(0);

    var inner = document.getElementById('epgInner');
    inner.innerHTML = '';

    // ── Ruler row ────────────────────────────────────────────────────────────
    var rulerRow = document.createElement('div');
    rulerRow.className = 'epg-ruler-row';

    var corner = document.createElement('div');
    corner.className = 'epg-corner';
    rulerRow.appendChild(corner);

    var ticks = document.createElement('div');
    ticks.className = 'epg-ruler-ticks';
    ticks.style.width = totalPx + 'px';
    for (var t = Math.ceil(displayStart / 30) * 30; t <= displayEnd; t += 30) {
      var tick = document.createElement('div');
      tick.className = 'epg-tick';
      tick.style.left = ((t - displayStart) * PX_PER_MIN) + 'px';
      tick.textContent = fmt12(t);
      ticks.appendChild(tick);
    }
    rulerRow.appendChild(ticks);
    inner.appendChild(rulerRow);

    // ── NOW line (spans all channel rows, positioned in inner) ───────────────
    var nowSec = isToday(date)
      ? new Date().getHours() * 3600 + new Date().getMinutes() * 60 + new Date().getSeconds()
      : -1;

    if (isToday(date)) {
      var nowMin = new Date().getHours() * 60 + new Date().getMinutes();
      if (nowMin >= displayStart && nowMin <= displayEnd) {
        var nowLine = document.createElement('div');
        nowLine.className = 'epg-now-line';
        nowLine.style.left = (160 + (nowMin - displayStart) * PX_PER_MIN) + 'px';
        nowLine.style.top  = '36px';
        nowLine.style.height = (tracks.length * CH_HEIGHT) + 'px';
        nowLine.style.position = 'absolute';
        inner.appendChild(nowLine);
      }
    }

    // ── Channel rows ─────────────────────────────────────────────────────────
    tracks.forEach(function(track, ri) {
      var row = document.createElement('div');
      row.className = 'epg-ch-row';
      row.style.height = CH_HEIGHT + 'px';

      // Channel label (sticky left)
      var cell = document.createElement('div');
      cell.className = 'epg-ch-cell';
      cell.innerHTML =
        '<div class="epg-ch-num">CH ' + String(ri + 1).padStart(2, '0') + '</div>' +
        '<div class="epg-ch-inner">' +
          '<span class="epg-ch-emoji">' + track.emoji + '</span>' +
          '<span class="epg-ch-name">' + escapeHtml(track.title) + '</span>' +
        '</div>';
      row.appendChild(cell);

      // Row content (program blocks + off zones)
      var content = document.createElement('div');
      content.className = 'epg-row-content';
      content.style.width = totalPx + 'px';

      // TV OFF zones
      var offLeft = document.createElement('div');
      offLeft.className = 'epg-off';
      offLeft.style.left  = '0';
      offLeft.style.width = (EPG_BUFFER * PX_PER_MIN) + 'px';
      if (ri === Math.floor(tracks.length / 2)) offLeft.innerHTML = '<span class="epg-off-label">TV OFF</span>';
      content.appendChild(offLeft);

      var offRight = document.createElement('div');
      offRight.className = 'epg-off';
      offRight.style.left  = ((h.close - displayStart) * PX_PER_MIN) + 'px';
      offRight.style.width = (EPG_BUFFER * PX_PER_MIN) + 'px';
      if (ri === Math.floor(tracks.length / 2)) offRight.innerHTML = '<span class="epg-off-label">TV OFF</span>';
      content.appendChild(offRight);

      // Program blocks
      var sched = computeChannelSchedule(track, date);
      sched.slots.forEach(function(slot) {
        if (!slot.video) return;
        var startPx = (slot.startMin - displayStart) * PX_PER_MIN;
        var widthPx = Math.max((slot.endMin - slot.startMin) * PX_PER_MIN - 3, 20);
        var isNow   = nowSec >= 0 && slot.startMin * 60 <= nowSec && slot.endMin * 60 > nowSec;
        var isPast  = nowSec >= 0 && slot.endMin * 60 <= nowSec;

        var block = document.createElement('div');
        block.className = 'epg-block' + (isNow ? ' is-now' : isPast ? ' is-past' : '');
        block.style.left   = startPx + 'px';
        block.style.width  = widthPx + 'px';
        block.style.top    = '5px';
        block.style.height = (CH_HEIGHT - 10) + 'px';

        var durMin = slot.endMin - slot.startMin;
        var durStr = durMin >= 60
          ? Math.floor(durMin / 60) + 'h' + (durMin % 60 ? ' ' + (durMin % 60) + 'm' : '')
          : durMin + 'm';

        var bInner = '';
        if (widthPx > 50)  bInner += '<div class="epg-block-time">' + fmt12(slot.startMin) + '</div>';
        bInner += '<div class="epg-block-title">' + escapeHtml(slot.video.title) + '</div>';
        if (widthPx > 100) bInner += '<div class="epg-block-dur">' + durStr + '</div>';
        if (isNow)         bInner += '<div class="epg-now-badge">NOW</div>';
        block.innerHTML = bInner;

        if (isNow) {
          block.style.cursor = 'pointer';
          block.addEventListener('click', (function(idx) {
            return function() { selectChannel(idx); closeTvGuide(); };
          }(ri)));
        }

        content.appendChild(block);
      });

      row.appendChild(content);
      inner.appendChild(row);
    });
  }

  // ── Position persistence ─────────────────────────────────────────────────

  function savePosition() {
    var track = tracks[trackIdx];
    localStorage.setItem('ezaz_watch_track', track.slug);
    localStorage.setItem('ezaz_watch_video', videoIdx);
    var dt = localStorage.getItem('ezaz_device_token');
    if (dt) {
      clearTimeout(syncTimer);
      syncTimer = setTimeout(function() {
        fetch('/api/watch/position', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ device_token: dt, track_slug: track.slug, video_index: videoIdx })
        }).catch(function() {});
      }, 600);
    }
  }

  function applyPosition(slug, _ignored) {
    // We honour the saved channel choice (so kids return to the channel they
    // last watched) but always join at the schedule's current position — never
    // resume from a stale video index. That's the whole point of broadcast feel.
    var idx = tracks.findIndex(function(t) { return t.slug === slug; });
    if (idx < 0) return;
    selectChannel(idx);
  }

  function loadSavedPosition() {
    var dt = localStorage.getItem('ezaz_device_token');
    if (dt) {
      fetch('/api/watch/position?device_token=' + encodeURIComponent(dt))
        .then(function(r) { return r.ok ? r.json() : {}; })
        .then(function(d) { if (d.track_slug) applyPosition(d.track_slug, d.video_index); })
        .catch(function() {});
    } else {
      var slug = localStorage.getItem('ezaz_watch_track');
      var vi   = parseInt(localStorage.getItem('ezaz_watch_video') || '0', 10);
      if (slug) applyPosition(slug, isNaN(vi) ? 0 : vi);
    }
  }

  // ── YouTube player ────────────────────────────────────────────────────────

  function initPlayer() {
    // Initial schedule for the default channel
    var info = nowPlaying(tracks[trackIdx]);
    activeSchedule = info.schedule;
    videoIdx = info.videoIndex;

    player = new YT.Player('yt-player', {
      videoId: activeSchedule[videoIdx].youtube_id,
      playerVars: {
        autoplay:       1,
        controls:       0,
        rel:            0,
        modestbranding: 1,
        iv_load_policy: 3,
        fs:             0,
        playsinline:    1,
        start:          info.offsetS
      },
      events: {
        onReady: function(e) {
          if (info.offsetS > 0) { try { e.target.seekTo(info.offsetS, true); } catch (_) {} }
          e.target.playVideo();
          updateDisplay();
        },
        onStateChange: function(e) {
          if (e.data === YT.PlayerState.PLAYING) { savePosition(); document.getElementById('player-blocker').style.display = 'none'; }
          if (e.data === YT.PlayerState.ENDED) {
            document.getElementById('player-blocker').style.display = 'block';
            advanceVideo(1);
          }
        },
        onError: function() {
          setTimeout(function() { advanceVideo(1); }, 1500);
        }
      }
    });
  }

  if (window._ytReady) {
    initPlayer();
  } else {
    window._ytCallbacks.push(initPlayer);
  }

  // ── ActionCable ───────────────────────────────────────────────────────────

  var consumer     = createConsumer();
  var subscription = consumer.subscriptions.create(
    { channel: 'TvRemoteChannel', token: token },
    {
      connected: function() {
        this.perform('set_state', { state: 'watch' });
      },
      received: function(data) {
        if (data.type === 'navigate' && data.nav_type !== 'release') {
          handleNav(data.direction);
        }
      }
    }
  );

  // ── Init ──────────────────────────────────────────────────────────────────

  if (!new URLSearchParams(location.search).get('t')) {
    history.replaceState({}, '', '/watch?t=' + token);
  }

  document.addEventListener('touchstart', showHud, { passive: true });

  updateDisplay();
  loadSavedPosition();
  showHud();
</script>

</body>
</html>
